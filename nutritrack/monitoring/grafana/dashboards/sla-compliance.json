      "id": 100,
      "title": "SLA Compliance Overview (C16)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Overall SLA Compliance",
      "description": "Weighted average of all SLA indicators. Target: > 95%",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(\n  (clamp_max(avg_over_time(airflow_dag_run_success_rate[24h]), 1) * 30) +\n  (clamp_max(1 - (time() - max(airflow_dag_run_end_timestamp)) / 86400, 1) * 25) +\n  (clamp_max(avg_over_time(airflow_task_finish{state=\"success\", task_id=~\"backup.*\"}[7d]), 1) * 25) +\n  (clamp_max(1 - clamp_min(pg_stat_activity_max_tx_duration{datname=\"nutritrack\"} / 5, 0), 1) * 20)\n) / 100 * 100",
          "legendFormat": "SLA Score",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "ETL Success Rate",
      "description": "Percentage of successful DAG runs over the last 24 hours. SLA target: > 95%",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(airflow_dagrun_duration_success_count[24h])) / (sum(increase(airflow_dagrun_duration_success_count[24h])) + sum(increase(airflow_dagrun_duration_failed_count[24h]))) * 100",
          "legendFormat": "Success Rate",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 18 },
              { "color": "orange", "value": 22 },
              { "color": "red", "value": 24 }
            ]
          },
          "unit": "h",
          "min": 0,
          "max": 48,
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
