      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(time() - max(airflow_dagrun_start_timestamp{dag_id=~\"etl_load_warehouse|etl_datalake_ingest\"})) / 3600",
          "legendFormat": "Hours Since Last Run",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
