      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(airflow_ti_successes{dag_id=\"etl_backup_maintenance\", task_id=~\"backup.*\"}[7d])) / (sum(increase(airflow_ti_successes{dag_id=\"etl_backup_maintenance\", task_id=~\"backup.*\"}[7d])) + sum(increase(airflow_ti_failures{dag_id=\"etl_backup_maintenance\", task_id=~\"backup.*\"}[7d]))) * 100",
          "legendFormat": "Backup Success",
          "refId": "A",
          "instant": true
