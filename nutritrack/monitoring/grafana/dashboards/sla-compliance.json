      "description": "Stacked bar chart of successful vs failed DAG runs per day.",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(airflow_dagrun_duration_success_count[1d])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(airflow_dagrun_duration_failed_count[1d])",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ]
