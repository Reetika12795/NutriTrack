# NutriTrack Environment Configuration
# Copy this to .env and adjust values as needed

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NUTRITRACK_DB_HOST=localhost
NUTRITRACK_DB_PORT=5432
NUTRITRACK_DB_NAME=nutritrack
NUTRITRACK_DB_USER=nutritrack
NUTRITRACK_DB_PASSWORD=nutritrack

# Redis
REDIS_URL=redis://localhost:6379/1

# MinIO (S3-compatible Data Lake)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# FastAPI
DATABASE_URL=postgresql+asyncpg://nutritrack:nutritrack@localhost:5432/nutritrack
JWT_SECRET_KEY=nutritrack-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Airflow
AIRFLOW__CORE__EXECUTOR=CeleryExecutor

# Streamlit
API_BASE_URL=http://localhost:8000
